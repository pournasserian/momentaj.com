---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

// Load services from CMS
const allServices = await getCollection('services');
const services = allServices.length > 0
  ? allServices
      .sort((a, b) => a.data.order - b.data.order)
      .map(service => service.data)
  : [];

// Icon mapping
const iconMap: Record<string, string> = {
  'code': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />',
  'mobile': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />',
  'link': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />',
  'cloud': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />',
  'consultation': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />',
  'design': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />'
};

// Map services to display format with links
const displayServices = services.map(service => ({
  ...service,
  href: `/services/${service.slug}`,
  icon: service.icon || 'code'
}));
---

<BaseLayout 
  title="Services - Momentaj | Custom Software Development & IT Consulting"
  description="Explore our wide range of software development and IT consulting services including web development, mobile apps, UI/UX design, cloud solutions, and more."
>
  <Header />
  
  <main>
    <section class="pt-44 pb-24 bg-color-bg">
      <div class="container-custom">
        <div class="max-w-3xl animate-fade-in-up">
          <h1 class="hero-title mb-8">
            Our Services
          </h1>
          <p class="hero-subtitle">
            We offer a comprehensive range of software development and IT consulting services tailored to meet your unique business needs.
          </p>
        </div>
      </div>
    </section>

    <section class="section-padding bg-color-bg-alt">
      <div class="container-custom">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {displayServices.map((service, index) => (
            <a href={service.href} class={`service-card group animate-stagger animate-delay-${(index + 1) * 100}`}>
              <div class="w-14 h-14 bg-color-bg rounded-2xl flex items-center justify-center mb-8 border border-color-border/50 group-hover:scale-110 transition-transform duration-500">
                <svg class="w-7 h-7 text-color-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={iconMap[service.icon] || iconMap['code']} />
              </div>
              <h2 class="text-2xl font-semibold text-color-primary mb-5 tracking-tight group-hover:text-color-accent transition-colors">
                {service.title}
              </h2>
              <p class="text-color-text-light leading-relaxed mb-8 text-[15px]">
                {service.short_description}
              </p>
              <span class="text-sm font-semibold text-color-accent inline-flex items-center group-hover:translate-x-1 transition-transform">
                Learn more <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="cta-section section-padding">
      <div class="container-custom">
        <div class="text-center max-w-3xl mx-auto">
          <h2 class="text-5xl md:text-6xl font-semibold text-white mb-10 tracking-tight">
            Ready to Get Started?
          </h2>
          <p class="text-xl text-white/60 mb-14 leading-relaxed">
            Contact us today for a free consultation and let's discuss how we can help your business grow.
          </p>
          <a href="/contact-us" class="bg-white text-black px-12 py-5 rounded-full font-semibold hover:scale-105 transition-all duration-500 inline-block">
            Free Consultation
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>
