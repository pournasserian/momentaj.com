---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getServices } from '../lib/content';

// Load services from CMS
const services = getServices();

// Icon mapping
const iconMap: Record<string, string> = {
  'code': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />',
  'mobile': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />',
  'link': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />',
  'cloud': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />',
  'consultation': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />',
  'design': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />'
};

// Map services to display format with links
const displayServices = services.map(service => ({
  ...service,
  href: `/services/${service.slug}`,
  icon: service.icon || 'code'
}));
---

<BaseLayout 
  title="Services - Momentaj | Custom Software Development & IT Consulting"
  description="Explore our wide range of software development and IT consulting services including web development, mobile apps, UI/UX design, cloud solutions, and more."
>
  <Header />
  
  <main>
    <section class="pt-32 pb-16 bg-slate-50">
      <div class="container-custom">
        <div class="max-w-3xl">
          <h1 class="text-4xl md:text-5xl font-bold text-primary mb-6">
            Our Services
          </h1>
          <p class="text-xl text-slate-600">
            We offer a comprehensive range of software development and IT consulting services tailored to meet your unique business needs.
          </p>
        </div>
      </div>
    </section>

    <section class="section-padding bg-white">
      <div class="container-custom">
        <div class="space-y-16">
          {displayServices.map((service, index) => (
            <div class="grid lg:grid-cols-2 gap-12 items-start">
              <div class={index % 2 === 1 ? 'lg:order-2' : ''}>
                <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mb-6">
                  <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={iconMap[service.icon] || iconMap['code']} />
                </div>
                <h2 class="text-2xl md:text-3xl font-bold text-primary mb-4">
                  {service.title}
                </h2>
                <p class="text-slate-600 leading-relaxed mb-6">
                  {service.short_description}
                </p>
                <a href={service.href} class="inline-flex items-center gap-2 text-accent font-medium hover:gap-3 transition-all">
                  Learn more
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section-padding bg-primary">
      <div class="container-custom">
        <div class="text-center max-w-3xl mx-auto">
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
            Ready to Get Started?
          </h2>
          <p class="text-xl text-white/80 mb-8">
            Contact us today for a free consultation and let's discuss how we can help your business grow.
          </p>
          <a href="/contact-us" class="bg-white text-primary px-8 py-4 rounded-lg font-semibold hover:bg-slate-100 transition-colors">
            Free Consultation
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>
