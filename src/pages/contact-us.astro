---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getEntry } from 'astro:content';

const settings = await getEntry('settings', 'settings');
const siteData = settings?.data;

const contactPage = await getEntry('pages', 'contact');

if (!contactPage) {
  return Astro.redirect('/404');
}

const { data: page } = contactPage;
---

<BaseLayout 
  title="Contact Us - Momentaj | Get in Touch"
  description="Contact Momentaj for a free consultation. We're ready to help with your software development and IT consulting needs."
>
  <Header />
  
  <main>
    <!-- Page Header -->
    <section class="pt-44 pb-24 bg-color-bg">
      <div class="container-custom">
        <div class="max-w-3xl animate-fade-in-up">
          <h1 class="hero-title mb-8">
            Let's build something <br /> extraordinary
          </h1>
          <p class="hero-subtitle">
            Have a question or want to discuss your project? We'd love to hear from you.
          </p>
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="pb-32 bg-color-bg">
      <div class="container-custom">
        <div class="grid lg:grid-cols-12 gap-20">
          <!-- Contact Info -->
          <div class="lg:col-span-4 animate-fade-in-up">
            <div class="space-y-16">
              {siteData?.email && (
                <div>
                  <h3 class="text-[11px] font-bold uppercase tracking-[0.2em] text-color-text-light2 mb-6">Email</h3>
                  <a href={`mailto:${siteData.email}`} class="text-2xl font-medium text-color-primary hover:text-color-accent transition-colors tracking-tight">
                    {siteData.email}
                  </a>
                </div>
              )}
              
              {siteData?.address && (
                <div>
                  <h3 class="text-[11px] font-bold uppercase tracking-[0.2em] text-color-text-light2 mb-6">Office</h3>
                  <p class="text-2xl font-medium text-color-primary leading-tight tracking-tight">
                    {siteData.address.split(',').map((part, i, arr) => (
                      <Fragment>{part.trim()}{i < arr.length - 1 ? <br/> : ''}</Fragment>
                    ))}
                  </p>
                </div>
              )}
              
              {siteData?.social_links?.linkedin && (
                <div>
                  <h3 class="text-[11px] font-bold uppercase tracking-[0.2em] text-color-text-light2 mb-6">Social</h3>
                  <a href={siteData.social_links.linkedin} target="_blank" rel="noopener noreferrer" class="text-2xl font-medium text-color-primary hover:text-color-accent transition-colors tracking-tight">
                    LinkedIn
                  </a>
                </div>
              )}
            </div>
          </div>
          
          <!-- Contact Form -->
          <div class="lg:col-span-8 animate-fade-in-up animate-delay-200">
            <form 
              action="https://api.web3forms.com/submit" 
              method="POST"
              class="space-y-12"
            >
              <input type="hidden" name="access_key" value="6534ba9d-139e-481a-9d06-0977b5815bf1" />
              <div class="grid md:grid-cols-2 gap-12">
                <div class="relative group">
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="peer w-full bg-transparent py-4 border-b border-color-border focus:border-color-accent transition-colors outline-none text-xl font-medium placeholder-transparent"
                    placeholder="Name"
                  />
                  <label for="name" class="absolute left-0 -top-3.5 text-color-text-light2 text-xs font-bold uppercase tracking-widest transition-all peer-placeholder-shown:text-xl peer-placeholder-shown:top-4 peer-placeholder-shown:font-medium peer-placeholder-shown:tracking-normal peer-focus:-top-3.5 peer-focus:text-xs peer-focus:font-bold peer-focus:tracking-widest peer-focus:text-color-accent">
                    Name *
                  </label>
                </div>
                
                <div class="relative group">
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="peer w-full bg-transparent py-4 border-b border-color-border focus:border-color-accent transition-colors outline-none text-xl font-medium placeholder-transparent"
                    placeholder="Email"
                  />
                  <label for="email" class="absolute left-0 -top-3.5 text-color-text-light2 text-xs font-bold uppercase tracking-widest transition-all peer-placeholder-shown:text-xl peer-placeholder-shown:top-4 peer-placeholder-shown:font-medium peer-placeholder-shown:tracking-normal peer-focus:-top-3.5 peer-focus:text-xs peer-focus:font-bold peer-focus:tracking-widest peer-focus:text-color-accent">
                    Email *
                  </label>
                </div>
              </div>
              
              <div class="grid md:grid-cols-2 gap-12">
                <div class="relative group">
                  <input
                    type="text"
                    id="company"
                    name="company"
                    class="peer w-full bg-transparent py-4 border-b border-color-border focus:border-color-accent transition-colors outline-none text-xl font-medium placeholder-transparent"
                    placeholder="Company"
                  />
                  <label for="company" class="absolute left-0 -top-3.5 text-color-text-light2 text-xs font-bold uppercase tracking-widest transition-all peer-placeholder-shown:text-xl peer-placeholder-shown:top-4 peer-placeholder-shown:font-medium peer-placeholder-shown:tracking-normal peer-focus:-top-3.5 peer-focus:text-xs peer-focus:font-bold peer-focus:tracking-widest peer-focus:text-color-accent">
                    Company
                  </label>
                </div>
                
                <div class="relative group">
                  <select
                    id="service"
                    name="service"
                    class="peer w-full bg-transparent py-4 border-b border-color-border focus:border-color-accent transition-colors outline-none text-xl font-medium appearance-none cursor-pointer"
                  >
                    <option value="" class="bg-color-bg">Select a service</option>
                    <option value="AI Consultation" class="bg-color-bg">AI Consultation</option>
                    <option value="Web Development" class="bg-color-bg">Web Development</option>
                    <option value="Mobile Development" class="bg-color-bg">Mobile Development</option>
                    <option value="Custom Software" class="bg-color-bg">Custom Software</option>
                    <option value="UI/UX Design" class="bg-color-bg">UI/UX Design</option>
                    <option value="Cloud DevOps" class="bg-color-bg">Cloud & DevOps</option>
                    <option value="Other" class="bg-color-bg">Other</option>
                  </select>
                  <label for="service" class="absolute left-0 -top-3.5 text-color-text-light2 text-xs font-bold uppercase tracking-widest">
                    Service
                  </label>
                  <div class="absolute right-0 top-5 pointer-events-none text-color-text-light2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </div>
                </div>
              </div>
              
              <div class="relative group">
                <textarea
                  id="message"
                  name="message"
                  rows="1"
                  required
                  class="peer w-full bg-transparent py-4 border-b border-color-border focus:border-color-accent transition-all outline-none text-xl font-medium placeholder-transparent resize-none min-h-[60px]"
                  placeholder="Message"
                ></textarea>
                <label for="message" class="absolute left-0 -top-3.5 text-color-text-light2 text-xs font-bold uppercase tracking-widest transition-all peer-placeholder-shown:text-xl peer-placeholder-shown:top-4 peer-placeholder-shown:font-medium peer-placeholder-shown:tracking-normal peer-focus:-top-3.5 peer-focus:text-xs peer-focus:font-bold peer-focus:tracking-widest peer-focus:text-color-accent">
                  Message *
                </label>
              </div>
              
              <div class="pt-6">
                <button
                  type="submit"
                  class="btn-primary !px-12 !py-5 !text-base group"
                >
                  Send Message
                  <svg class="w-5 h-5 ml-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                  </svg>
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>

<script>
  // Auto-expand textarea
  const textarea = document.getElementById('message');
  textarea?.addEventListener('input', () => {
    textarea.style.height = 'auto';
    textarea.style.height = textarea.scrollHeight + 'px';
  });
</script>
