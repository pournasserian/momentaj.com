---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { marked } from 'marked';

// Generate static paths for all services
export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((service) => ({
    params: { slug: service.data.slug },
  }));
}

// Get the slug from the URL
const { slug } = Astro.params;

// Load service data
const allServices = await getCollection('services');
const serviceEntry = allServices.find(s => s.data.slug === slug);

// If not found, show 404
if (!serviceEntry) {
  return Astro.redirect('/404');
}

const service = serviceEntry.data;

// Get related services (other than current)
const relatedServices = allServices
  .filter(s => s.data.slug !== slug)
  .slice(0, 3)
  .map(s => ({ title: s.data.title, href: `/services/${s.data.slug}`, description: s.data.short_description }));

// Icon mapping
const iconMap: Record<string, string> = {
  'code': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />',
  'mobile': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />',
  'link': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />',
  'cloud': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />',
  'consultation': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />',
  'design': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />'
};

const iconPath = iconMap[service.icon || 'code'] || iconMap['code'];

// Render markdown content
const htmlContent = await marked.parse(service.content || '');
---

<BaseLayout 
  title={`${service.title} | Momentaj Services`}
  description={service.short_description}
>
  <Header />
  
  <main>
    <!-- Breadcrumbs -->
    <nav class="pt-32 bg-color-bg">
      <div class="container-custom py-4">
        <ol class="flex items-center gap-3 text-[11px] font-bold uppercase tracking-widest">
          <li><a href="/" class="text-color-text-light2 hover:text-color-primary transition-colors">Home</a></li>
          <li><span class="text-color-border">/</span></li>
          <li><a href="/services" class="text-color-text-light2 hover:text-color-primary transition-colors">Services</a></li>
          <li><span class="text-color-border">/</span></li>
          <li class="text-color-accent">{service.title}</li>
        </ol>
      </div>
    </nav>

    <!-- Hero -->
    <section class="pt-12 pb-24 bg-color-bg">
      <div class="container-custom">
        <div class="max-w-4xl animate-fade-in-up">
          <div class="w-16 h-16 bg-color-bg-alt rounded-2xl flex items-center justify-center mb-10 border border-color-border/50">
            <svg class="w-8 h-8 text-color-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={iconPath} />
          </div>
          <h1 class="hero-title mb-8">{service.title}</h1>
          <p class="hero-subtitle max-w-2xl">{service.short_description}</p>
        </div>
      </div>
    </section>

    <!-- Content - Minimal and Natural -->
    <section class="pb-32 bg-color-bg">
      <div class="container-custom">
        <div class="max-w-3xl animate-fade-in-up animate-delay-200">
          <div class="prose prose-lg dark:prose-invert max-w-none 
            prose-headings:text-color-primary prose-headings:font-semibold prose-headings:tracking-tight prose-headings:mb-6 prose-headings:mt-12 first:prose-headings:mt-0
            prose-p:text-color-text-light prose-p:leading-relaxed prose-p:text-[18px] prose-p:mb-8
            prose-ul:my-8 prose-ul:space-y-4
            prose-li:text-color-text-light prose-li:text-[17px] prose-li:pl-2
            prose-strong:text-color-primary
            prose-hr:my-12 prose-hr:border-color-border/30" 
            set:html={htmlContent} 
          />
        </div>
      </div>
    </section>

    <!-- Related Services -->
    {relatedServices.length > 0 && (
      <section class="section-padding bg-color-bg-alt border-t border-color-border/30">
        <div class="container-custom">
          <div class="mb-16">
            <h2 class="section-title !text-3xl md:!text-4xl">Other Services</h2>
          </div>
          <div class="grid md:grid-cols-3 gap-8">
            {relatedServices.map((relService, index) => (
              <a href={relService.href} class={`service-card group animate-stagger animate-delay-${(index + 1) * 100}`}>
                <h3 class="text-xl font-semibold text-color-primary mb-4 tracking-tight group-hover:text-color-accent transition-colors">{relService.title}</h3>
                <p class="text-color-text-light text-sm leading-relaxed line-clamp-2">{relService.description}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="cta-section section-padding">
      <div class="container-custom">
        <div class="text-center max-w-3xl mx-auto">
          <h2 class="text-5xl md:text-6xl font-semibold text-white mb-10 tracking-tight">Ready to Get Started?</h2>
          <p class="text-xl text-white/60 mb-14 leading-relaxed">Contact us today for a free consultation on {service.title}.</p>
          <a href="/contact-us" class="bg-white text-black px-12 py-5 rounded-full font-semibold hover:scale-105 transition-all duration-500 inline-block">
            Get Started
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>
