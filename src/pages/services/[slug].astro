---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getServiceBySlug, getServiceSlugs, getServices } from '../../lib/content';

// Generate static paths for all services
export function getStaticPaths() {
  const slugs = getServiceSlugs();
  return slugs.map((slug) => ({
    params: { slug },
  }));
}

// Get the slug from the URL
const { slug } = Astro.params;

// Load service data
const service = getServiceBySlug(slug);

// If not found, show 404
if (!service) {
  return Astro.redirect('/404');
}

// Get related services (other than current)
const allServices = getServices();
const relatedServices = allServices
  .filter(s => s.slug !== slug)
  .slice(0, 3)
  .map(s => ({ title: s.title, href: `/services/${s.slug}`, description: s.short_description }));

// Icon mapping
const iconMap: Record<string, string> = {
  'code': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />',
  'mobile': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />',
  'link': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />',
  'cloud': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />',
  'consultation': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />',
  'design': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />'
};

const iconPath = iconMap[service.icon || 'code'] || iconMap['code'];

// Parse content into sections
const contentSections = service.content ? service.content.split('\n\n') : [];
---

<BaseLayout 
  title={`${service.title} | Momentaj Services`}
  description={service.short_description}
>
  <Header />
  
  <main>
    <nav class="pt-24 bg-slate-50 border-b border-slate-200">
      <div class="container-custom py-3">
        <ol class="flex items-center gap-2 text-sm">
          <li><a href="/" class="text-slate-500 hover:text-primary">Home</a></li>
          <li><span class="text-slate-400">/</span></li>
          <li><a href="/services" class="text-slate-500 hover:text-primary">Services</a></li>
          <li><span class="text-slate-400">/</span></li>
          <li class="text-primary font-medium">{service.title}</li>
        </ol>
      </div>
    </nav>

    <!-- Hero -->
    <section class="py-16 bg-gradient-to-br from-primary to-primary-light">
      <div class="container-custom">
        <div class="max-w-4xl">
          <div class="w-20 h-20 bg-white/10 rounded-2xl flex items-center justify-center mb-6">
            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={iconPath} />
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">{service.title}</h1>
          <p class="text-xl text-white/80 mb-8">{service.short_description}</p>
        </div>
      </div>
    </section>

    <!-- Content -->
    <section class="section-padding bg-white">
      <div class="container-custom">
        <div class="max-w-3xl">
          {contentSections.length > 0 ? (
            contentSections.map((section) => (
              <div class="mb-8">
                {section.startsWith('## ') ? (
                  <h2 class="text-2xl font-bold text-primary mb-4">{section.replace('## ', '')}</h2>
                ) : section.startsWith('### ') ? (
                  <h3 class="text-xl font-semibold text-primary mb-3">{section.replace('### ', '')}</h3>
                ) : section.startsWith('- ') ? (
                  <ul class="list-disc list-inside text-slate-600 space-y-2">
                    {section.split('\n').filter(s => s.startsWith('- ')).map(item => (
                      <li class="ml-4">{item.replace('- ', '')}</li>
                    ))}
                  </ul>
                ) : (
                  <p class="text-slate-600 leading-relaxed">{section}</p>
                )}
              </div>
            ))
          ) : (
            <p class="text-slate-600">{service.short_description}</p>
          )}
        </div>
      </div>
    </section>

    <!-- Related Services -->
    {relatedServices.length > 0 && (
      <section class="section-padding bg-slate-50">
        <div class="container-custom">
          <h2 class="text-3xl font-bold text-primary mb-8 text-center">Other Services</h2>
          <div class="grid md:grid-cols-3 gap-6">
            {relatedServices.map((relService) => (
              <a href={relService.href} class="bg-white p-6 rounded-xl hover:shadow-lg transition-shadow">
                <h3 class="text-lg font-semibold text-primary mb-2">{relService.title}</h3>
                <p class="text-slate-600 text-sm">{relService.description}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="section-padding bg-primary">
      <div class="container-custom">
        <div class="text-center max-w-3xl mx-auto">
          <h2 class="text-3xl font-bold text-white mb-6">Ready to Get Started?</h2>
          <p class="text-xl text-white/80 mb-8">Contact us today for a free consultation on {service.title}.</p>
          <a href="/contact-us" class="bg-white text-primary px-8 py-4 rounded-lg font-semibold hover:bg-slate-100 transition-colors">
            Get Started
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>
