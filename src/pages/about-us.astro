---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getEntry } from 'astro:content';

const aboutPage = await getEntry('pages', 'about');

if (!aboutPage) {
  return Astro.redirect('/404');
}

const { data: page } = aboutPage;

const team = [
  {
    name: 'John Smith',
    role: 'CEO & Founder',
    bio: 'Visionary leader with 15+ years in software development and IT consulting.',
  },
  {
    name: 'Sarah Johnson',
    role: 'CTO',
    bio: 'Technical expert specializing in cloud architecture and enterprise solutions.',
  },
  {
    name: 'Michael Chen',
    role: 'Head of Development',
    bio: 'Full-stack developer with expertise in .NET, Node.js, and modern frameworks.',
  },
  {
    name: 'Emily Davis',
    role: 'Design Lead',
    bio: 'Creative designer focused on crafting exceptional user experiences.',
  }
];

const values = [
  {
    title: 'Excellence',
    description: 'We strive for excellence in everything we do, from code quality to client communication.',
    icon: 'star'
  },
  {
    title: 'Innovation',
    description: 'We embrace new technologies and innovative approaches to solve complex challenges.',
    icon: 'lightbulb'
  },
  {
    title: 'Collaboration',
    description: 'We work closely with our clients as partners, fostering long-term relationships.',
    icon: 'users'
  },
  {
    title: 'Reliability',
    description: 'We deliver on our promises, meeting deadlines and exceeding expectations consistently.',
    icon: 'shield'
  }
];
---

<BaseLayout 
  title="About Us - Momentaj | Our Story & Team"
  description="Learn about Momentaj, a leading software development and IT consulting company based in Toronto, and meet our team of experts."
>
  <Header />
  
  <main>
    <!-- Page Header -->
    <section class="pt-44 pb-24 bg-color-bg">
      <div class="container-custom">
        <div class="max-w-3xl animate-fade-in-up">
          <h1 class="hero-title mb-8">
            About Us
          </h1>
          <p class="hero-subtitle">
            We are a team of passionate developers, designers, and consultants dedicated to helping businesses succeed through technology.
          </p>
        </div>
      </div>
    </section>

    <!-- Our Story -->
    <section class="section-padding bg-color-bg-alt">
      <div class="container-custom">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div class="animate-fade-in-up">
            <h2 class="section-title !text-3xl md:!text-4xl mb-8">
              Our Story
            </h2>
            <div class="space-y-6 text-color-text-light leading-relaxed text-[16px]">
              <p>
                Founded in Toronto, Momentaj was built on the belief that businesses deserve better software solutions. We saw too many companies struggling with outdated systems, inefficient processes, and one-size-fits-all solutions that didn't address their unique needs.
              </p>
              <p>
                Today, we're proud to be a leading software development and IT consulting company, serving clients across various industries. Our team of experts combines technical excellence with business acumen to deliver solutions that drive real results.
              </p>
              <p>
                We believe in building long-term partnerships with our clients, understanding their challenges, and delivering tailored solutions that help them achieve their goals. Our commitment to quality, innovation, and client satisfaction has earned us a reputation as a trusted technology partner.
              </p>
            </div>
          </div>
          <div class="animate-fade-in-up animate-delay-200">
            <div class="grid grid-cols-2 gap-6">
              <div class="stat-card">
                <div class="text-4xl font-semibold text-color-primary mb-2 tracking-tight">5+</div>
                <div class="text-[10px] font-bold text-color-text-light uppercase tracking-widest">Years Experience</div>
              </div>
              <div class="stat-card">
                <div class="text-4xl font-semibold text-color-primary mb-2 tracking-tight">50+</div>
                <div class="text-[10px] font-bold text-color-text-light uppercase tracking-widest">Projects Delivered</div>
              </div>
              <div class="stat-card">
                <div class="text-4xl font-semibold text-color-primary mb-2 tracking-tight">30+</div>
                <div class="text-[10px] font-bold text-color-text-light uppercase tracking-widest">Happy Clients</div>
              </div>
              <div class="stat-card">
                <div class="text-4xl font-semibold text-color-primary mb-2 tracking-tight">15+</div>
                <div class="text-[10px] font-bold text-color-text-light uppercase tracking-widest">Team Members</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Values -->
    <section class="section-padding bg-color-bg">
      <div class="container-custom">
        <div class="text-center max-w-3xl mx-auto mb-24">
          <h2 class="section-title">Our Values</h2>
          <p class="section-subtitle mx-auto">
            The principles that guide everything we do.
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {values.map((value, index) => (
            <div class={`feature-card animate-stagger animate-delay-${(index + 1) * 100}`}>
              <div class="w-12 h-12 bg-color-bg rounded-xl flex items-center justify-center mb-8 border border-color-border/50">
                <svg class="w-6 h-6 text-color-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  {value.icon === 'star' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />}
                  {value.icon === 'lightbulb' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />}
                  {value.icon === 'users' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />}
                  {value.icon === 'shield' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />}
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-color-primary mb-4 tracking-tight">
                {value.title}
              </h3>
              <p class="text-color-text-light text-[15px] leading-relaxed">
                {value.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Team -->
    <section class="section-padding bg-color-bg-alt">
      <div class="container-custom">
        <div class="text-center max-w-3xl mx-auto mb-24">
          <h2 class="section-title">Meet Our Team</h2>
          <p class="section-subtitle mx-auto">
            The talented people behind our success.
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {team.map((member, index) => (
            <div class={`case-study-card group animate-stagger animate-delay-${(index + 1) * 100}`}>
              <div class="h-64 bg-color-bg flex items-center justify-center border-b border-color-border/50 overflow-hidden">
                <div class="transform group-hover:scale-110 transition-transform duration-1000">
                  <svg class="w-20 h-20 text-color-text-light2 opacity-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                </div>
              </div>
              <div class="p-8">
                <h3 class="text-lg font-semibold text-color-primary mb-1 tracking-tight">
                  {member.name}
                </h3>
                <p class="text-color-accent text-[11px] font-bold uppercase tracking-widest mb-4">{member.role}</p>
                <p class="text-color-text-light text-sm leading-relaxed">
                  {member.bio}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section section-padding">
      <div class="container-custom">
        <div class="text-center max-w-3xl mx-auto">
          <h2 class="text-5xl md:text-6xl font-semibold text-white mb-10 tracking-tight">
            Let's Work Together
          </h2>
          <p class="text-xl text-white/60 mb-14 leading-relaxed">
            Ready to transform your business with custom software solutions? Get in touch with us today.
          </p>
          <a href="/contact-us" class="bg-white text-black px-12 py-5 rounded-full font-semibold hover:scale-105 transition-all duration-500 inline-block">
            Contact Us
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>
