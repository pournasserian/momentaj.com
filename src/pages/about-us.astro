---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const team = [
  {
    name: 'John Smith',
    role: 'CEO & Founder',
    bio: 'Visionary leader with 15+ years in software development and IT consulting.',
    color: 'from-slate-500 to-slate-700'
  },
  {
    name: 'Sarah Johnson',
    role: 'CTO',
    bio: 'Technical expert specializing in cloud architecture and enterprise solutions.',
    color: 'from-blue-500 to-blue-700'
  },
  {
    name: 'Michael Chen',
    role: 'Head of Development',
    bio: 'Full-stack developer with expertise in .NET, Node.js, and modern frameworks.',
    color: 'from-purple-500 to-purple-700'
  },
  {
    name: 'Emily Davis',
    role: 'Design Lead',
    bio: 'Creative designer focused on crafting exceptional user experiences.',
    color: 'from-pink-500 to-pink-700'
  }
];

const values = [
  {
    title: 'Excellence',
    description: 'We strive for excellence in everything we do, from code quality to client communication.',
    icon: 'star'
  },
  {
    title: 'Innovation',
    description: 'We embrace new technologies and innovative approaches to solve complex challenges.',
    icon: 'lightbulb'
  },
  {
    title: 'Collaboration',
    description: 'We work closely with our clients as partners, fostering long-term relationships.',
    icon: 'users'
  },
  {
    title: 'Reliability',
    description: 'We deliver on our promises, meeting deadlines and exceeding expectations consistently.',
    icon: 'shield'
  }
];
---

<BaseLayout 
  title="About Us - Momentaj | Our Story & Team"
  description="Learn about Momentaj, a leading software development and IT consulting company based in Toronto, and meet our team of experts."
>
  <Header />
  
  <main>
    <!-- Page Header -->
    <section class="pt-32 pb-16 bg-slate-50">
      <div class="container-custom">
        <div class="max-w-3xl">
          <h1 class="text-4xl md:text-5xl font-bold text-primary mb-6">
            About Us
          </h1>
          <p class="text-xl text-slate-600">
            We are a team of passionate developers, designers, and consultants dedicated to helping businesses succeed through technology.
          </p>
        </div>
      </div>
    </section>

    <!-- Our Story -->
    <section class="section-padding bg-white">
      <div class="container-custom">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-3xl font-bold text-primary mb-6">
              Our Story
            </h2>
            <div class="space-y-4 text-slate-600 leading-relaxed">
              <p>
                Founded in Toronto, Momentaj was built on the belief that businesses deserve better software solutions. We saw too many companies struggling with outdated systems, inefficient processes, and one-size-fits-all solutions that didn't address their unique needs.
              </p>
              <p>
                Today, we're proud to be a leading software development and IT consulting company, serving clients across various industries. Our team of experts combines technical excellence with business acumen to deliver solutions that drive real results.
              </p>
              <p>
                We believe in building long-term partnerships with our clients, understanding their challenges, and delivering tailored solutions that help them achieve their goals. Our commitment to quality, innovation, and client satisfaction has earned us a reputation as a trusted technology partner.
              </p>
            </div>
          </div>
          <div class="relative">
            <div class="absolute inset-0 bg-gradient-to-tr from-primary/20 to-accent/20 rounded-3xl blur-3xl"></div>
            <div class="relative bg-white rounded-2xl shadow-xl p-8 border border-slate-100">
              <div class="grid grid-cols-2 gap-6">
                <div class="text-center p-6 bg-slate-50 rounded-xl">
                  <div class="text-4xl font-bold text-primary mb-2">5+</div>
                  <div class="text-sm text-slate-500">Years Experience</div>
                </div>
                <div class="text-center p-6 bg-slate-50 rounded-xl">
                  <div class="text-4xl font-bold text-primary mb-2">50+</div>
                  <div class="text-sm text-slate-500">Projects Delivered</div>
                </div>
                <div class="text-center p-6 bg-slate-50 rounded-xl">
                  <div class="text-4xl font-bold text-primary mb-2">30+</div>
                  <div class="text-sm text-slate-500">Happy Clients</div>
                </div>
                <div class="text-center p-6 bg-slate-50 rounded-xl">
                  <div class="text-4xl font-bold text-primary mb-2">15+</div>
                  <div class="text-sm text-slate-500">Team Members</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Values -->
    <section class="section-padding bg-slate-50">
      <div class="container-custom">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="section-title">Our Values</h2>
          <p class="section-subtitle mx-auto">
            The principles that guide everything we do.
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {values.map((value) => (
            <div class="bg-white p-8 rounded-2xl shadow-sm hover:shadow-lg transition-all duration-300 border border-slate-100">
              <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center mb-6">
                <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  {value.icon === 'star' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />}
                  {value.icon === 'lightbulb' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />}
                  {value.icon === 'users' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />}
                  {value.icon === 'shield' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />}
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-primary mb-3">
                {value.title}
              </h3>
              <p class="text-slate-600 text-sm leading-relaxed">
                {value.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Team -->
    <section class="section-padding bg-white">
      <div class="container-custom">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="section-title">Meet Our Team</h2>
          <p class="section-subtitle mx-auto">
            The talented people behind our success.
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {team.map((member) => (
            <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-slate-100 group">
              <div class={`h-64 bg-gradient-to-br ${member.color} flex items-center justify-center`}>
                <svg class="w-24 h-24 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
              <div class="p-6">
                <h3 class="text-lg font-semibold text-primary mb-1">
                  {member.name}
                </h3>
                <p class="text-accent text-sm font-medium mb-3">{member.role}</p>
                <p class="text-slate-600 text-sm">
                  {member.bio}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="section-padding bg-primary">
      <div class="container-custom">
        <div class="text-center max-w-3xl mx-auto">
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
            Let's Work Together
          </h2>
          <p class="text-xl text-white/80 mb-8">
            Ready to transform your business with custom software solutions? Get in touch with us today.
          </p>
          <a href="/contact-us" class="bg-white text-primary px-8 py-4 rounded-lg font-semibold hover:bg-slate-100 transition-colors">
            Contact Us
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>
