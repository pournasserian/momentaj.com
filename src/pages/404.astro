---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout 
  title="404 - Page Not Found | Momentaj"
  description="The page you're looking for doesn't exist. Explore our software development services or contact us for assistance."
>
  <Header />
  
  <main>
    <section class="min-h-[70vh] flex items-center pt-24 pb-16 bg-color-bg">
      <div class="container-custom">
        <div class="max-w-2xl mx-auto text-center animate-fade-in-up">
          <div class="mb-8 md:mb-12">
            <span class="text-[120px] md:text-[180px] font-bold text-color-border leading-none">404</span>
          </div>
          <h1 class="hero-title mb-6 md:mb-8">Page Not Found</h1>
          <p class="hero-subtitle mb-10 md:mb-14 max-w-lg mx-auto">
            The page you're looking for doesn't exist or has been moved. Let's get you back on track.
          </p>
          <div class="flex flex-wrap justify-center gap-4 md:gap-6">
            <a href="/" class="btn-primary text-sm md:text-base py-3 px-6 md:py-4 md:px-8">
              Go Home
            </a>
            <a href="/services" class="btn-secondary text-sm md:text-base py-3 px-6 md:py-4 md:px-8">
              Our Services
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>