---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getEntry, getCollection } from 'astro:content';

// Load settings
const settings = await getEntry('settings', 'settings');
const siteData = settings?.data;

// Load content from CMS
const allCaseStudies = await getCollection('case-studies');
const featuredCaseStudies = allCaseStudies.length > 0
  ? allCaseStudies
      .filter(study => study.data.featured)
      .sort((a, b) => a.data.order - b.data.order)
      .slice(0, 3)
      .map(study => study.data)
  : [];

const allServices = await getCollection('services');
const services = allServices.length > 0
  ? allServices
      .sort((a, b) => a.data.order - b.data.order)
      .slice(0, 6)
      .map(service => service.data)
  : [];

const features = [
  {
    title: 'On-demand, Flexible',
    description: 'Our flexible approach to software development and IT consulting allows businesses to meet their unique needs and scale as required.',
  },
  {
    title: 'Cost Benefit',
    description: "Cost-effective solutions that provide high-quality, reliable service that is both affordable and sustainable.",
  },
  {
    title: 'Agile Team',
    description: 'Our agile team is responsive, collaborative, and highly skilled in developing software solutions.',
  },
  {
    title: 'Eliminate Risk',
    description: "We help businesses eliminate risk and ensure systems are reliable, efficient, and secure.",
  }
];

const techStack = {
  frontend: [
    { name: 'React', logo: 'https://cdn.simpleicons.org/react/000000' },
    { name: 'Vue.js', logo: 'https://cdn.simpleicons.org/vuedotjs/000000' },
    { name: 'Angular', logo: 'https://cdn.simpleicons.org/angular/000000' },
    { name: 'Svelte', logo: 'https://cdn.simpleicons.org/svelte/000000' },
    { name: 'TailwindCSS', logo: 'https://cdn.simpleicons.org/tailwindcss/000000' },
    { name: 'TypeScript', logo: 'https://cdn.simpleicons.org/typescript/000000' }
  ],
  backend: [
    { name: 'Node.js', logo: 'https://cdn.simpleicons.org/nodedotjs/000000' },
    { name: 'Python', logo: 'https://cdn.simpleicons.org/python/000000' },
    { name: '.NET', logo: 'https://cdn.simpleicons.org/dotnet/000000' },
    { name: 'Go', logo: 'https://cdn.simpleicons.org/go/000000' }
  ],
  mobile: [
    { name: 'iOS', logo: 'https://cdn.simpleicons.org/apple/000000' },
    { name: 'Android', logo: 'https://cdn.simpleicons.org/android/000000' },
    { name: 'Flutter', logo: 'https://cdn.simpleicons.org/flutter/000000' },
    { name: 'React Native', logo: 'https://cdn.simpleicons.org/react/000000' }
  ],
  cloud: [
    { name: 'AWS', logo: 'https://cdn.simpleicons.org/amazonwebservices/000000' },
    { name: 'Azure', logo: 'https://cdn.simpleicons.org/microsoftazure/000000' },
    { name: 'Google Cloud', logo: 'https://cdn.simpleicons.org/googlecloud/000000' },
    { name: 'Docker', logo: 'https://cdn.simpleicons.org/docker/000000' }
  ]
};
---

<BaseLayout title={siteData?.site_title || "Momentaj - Tailored Software Solutions for Unique Business Needs"}>
  <Header />
  
  <main>
    <!-- Hero Section - Clean and minimal -->
    <section class="min-h-[95vh] flex items-center pt-20 bg-color-bg overflow-hidden" aria-labelledby="hero-heading">
      <div class="container-custom">
        <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
          <div class="max-w-2xl animate-fade-in-up">
            <p class="text-[13px] font-bold text-color-accent mb-8 tracking-[0.2em] uppercase">Based in Toronto, Canada</p>
            <h1 id="hero-heading" class="hero-title mb-10">
              Software that <br class="hidden md:block" /> drives results
            </h1>
            <p class="hero-subtitle mb-12 max-w-lg">
              {siteData?.site_description || 'Tailored software solutions for unique business needs. We build high-performance digital products that drive growth.'}
            </p>
            <div class="flex flex-wrap gap-6">
              <a href="/services" class="btn-primary">
                Get Started
              </a>
              <a href="/contact-us" class="btn-secondary">
                Free Consultation
              </a>
            </div>
          </div>
          
          <!-- Simple stats - no glass, no shadows -->
          <div class="hidden lg:block animate-fade-in-up animate-delay-200">
            <div class="grid grid-cols-2 gap-8">
              <div class="stat-card">
                <div class="text-6xl font-semibold text-color-primary mb-3 tracking-tighter">5+</div>
                <div class="text-[11px] font-bold text-color-text-light uppercase tracking-[0.15em]">Years Experience</div>
              </div>
              <div class="stat-card">
                <div class="text-6xl font-semibold text-color-primary mb-3 tracking-tighter">50+</div>
                <div class="text-[11px] font-bold text-color-text-light uppercase tracking-[0.15em]">Projects Completed</div>
              </div>
              <div class="stat-card">
                <div class="text-6xl font-semibold text-color-primary mb-3 tracking-tighter">30+</div>
                <div class="text-[11px] font-bold text-color-text-light uppercase tracking-[0.15em]">Clients Worldwide</div>
              </div>
              <div class="stat-card">
                <div class="text-6xl font-semibold text-color-primary mb-3 tracking-tighter">99%</div>
                <div class="text-[11px] font-bold text-color-text-light uppercase tracking-[0.15em]">Satisfaction</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Client Logos - Simple and clean -->
    <section class="py-24 bg-color-bg border-t border-color-border/50">
      <div class="container-custom">
        <p class="text-center text-[11px] font-bold uppercase tracking-[0.25em] text-color-text-light2 mb-16">Trusted by industry leaders</p>
        <div class="flex flex-wrap justify-center items-center gap-16 md:gap-28">
          {['FluentCMS', 'Lendin', 'Marvic', 'Momentrack', 'QuadPro', 'TripSupport'].map(client => (
            <span class="client-logo">{client}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- Why Momentaj - Clean cards, no shadows -->
    <section class="section-padding bg-color-bg" aria-labelledby="why-heading">
      <div class="container-custom">
        <div class="text-center max-w-3xl mx-auto mb-28 animate-fade-in-up">
          <h2 id="why-heading" class="section-title">Why Momentaj</h2>
          <p class="section-subtitle mx-auto">
            We deliver excellence through our commitment to quality, innovation, and client success.
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {features.map((feature, index) => (
            <div class={`feature-card animate-stagger animate-delay-${(index + 1) * 100}`}>
              <h3 class="text-xl font-semibold mb-5 tracking-tight">{feature.title}</h3>
              <p class="text-color-text-light leading-relaxed text-[15px]">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Services Section - Clean grid -->
    <section class="section-padding bg-color-bg-alt" aria-labelledby="services-heading">
      <div class="container-custom">
        <div class="text-center max-w-3xl mx-auto mb-28">
          <h2 id="services-heading" class="section-title">What We Offer</h2>
          <p class="section-subtitle mx-auto">
            We offer a wide range of services to help you achieve your business goals.
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {services.map((service) => (
            <a href={`/services/${service.slug}`} class="service-card bg-color-bg/50 border border-color-text/10 group">
              <h3 class="text-2xl font-semibold mb-5 group-hover:text-color-accent transition-colors tracking-tight">
                {service.title}
              </h3>
              <p class="text-color-text-light leading-relaxed mb-8 text-[15px]">
                {service.short_description}
              </p>
              <span class="text-sm font-semibold text-color-accent inline-flex items-center group-hover:translate-x-1 transition-transform">
                Learn more <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              </span>
            </a>
          ))}
        </div>
        
        <div class="text-center mt-24">
          <a href="/services" class="link-underline font-semibold text-sm uppercase tracking-widest">
            View All Services
          </a>
        </div>
      </div>
    </section>

    <!-- Tech Stack - Simple list -->
    <section class="section-padding bg-color-bg" aria-labelledby="tech-heading">
      <div class="container-custom">
        <div class="text-center max-w-3xl mx-auto mb-28">
          <h2 id="tech-heading" class="section-title">Our Tech Stack</h2>
          <p class="section-subtitle mx-auto">
            Cutting-edge software stacks utilizing the latest technologies and best practices.
          </p>
        </div>
        
        <div class="space-y-24">
          {Object.entries(techStack).map(([category, techs]) => (
            <div>
              <h3 class="text-[11px] font-bold uppercase tracking-[0.2em] text-color-text-light2 mb-12 text-center">{category}</h3>
              <div class="flex flex-wrap justify-center gap-10 md:gap-16">
                {techs.map((tech) => (
                  <div class="flex flex-col items-center group">
                    <div class="tech-logo mb-5">
                      <img src={tech.logo} alt={tech.name} class="dark:invert" loading="lazy" />
                    </div>
                    <span class="text-[11px] font-bold uppercase tracking-wider text-color-text-light opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-y-2 group-hover:translate-y-0">{tech.name}</span>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Case Studies - Clean cards -->
    <section class="section-padding bg-color-bg-alt" aria-labelledby="case-studies-heading">
      <div class="container-custom">
        <div class="text-center max-w-3xl mx-auto mb-28">
          <h2 id="case-studies-heading" class="section-title">Case Studies</h2>
          <p class="section-subtitle mx-auto">
            Tailored solutions for a variety of needs, from custom software development to IT consulting.
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-10">
          {featuredCaseStudies.map((study) => (
            <a href={study.url || `/case-studies/${study.slug}`} target={study.url ? "_blank" : "_self"} class="case-study-card bg-color-bg/50 border border-color-text/10 group">
              <div class="h-72 bg-color-bg-alt flex items-center justify-center border-b border-color-border/50 overflow-hidden">
                <div class="transform group-hover:scale-110 transition-transform duration-1000">
                  <svg class="w-20 h-20 text-color-text-light2 opacity-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
              </div>
              <div class="p-12">
                <div class="text-[11px] font-bold uppercase tracking-[0.2em] text-color-accent mb-5">{study.client}</div>
                <h3 class="text-2xl font-semibold mb-6 group-hover:text-color-accent transition-colors leading-tight tracking-tight">{study.title}</h3>
                <div class="flex flex-wrap gap-3 mt-8">
                  {study.tags && study.tags.map(tag => (
                    <span class="text-[10px] font-bold uppercase tracking-widest px-4 py-1.5 rounded-full bg-color-bg text-color-text-light border border-color-border/50">{tag}</span>
                  ))}
                </div>
              </div>
            </a>
          ))}
        </div>
        
        <div class="text-center mt-24">
          <a href="/case-studies" class="link-underline font-semibold text-sm uppercase tracking-widest">
            View All Case Studies
          </a>
        </div>
      </div>
    </section>

    <!-- CTA Section - Minimal and clean -->
    <section class="cta-section section-padding" aria-labelledby="cta-heading">
      <div class="container-custom">
        <div class="text-center max-w-3xl mx-auto">
          <h2 id="cta-heading" class="text-5xl md:text-6xl lg:text-7xl font-semibold text-white mb-10 tracking-tight leading-tight">
            Ready to transform <br /> your business?
          </h2>
          <p class="text-xl text-white/60 mb-14 leading-relaxed">
            Let's discuss how we can help you achieve your business goals with high-performance software.
          </p>
          <div class="flex flex-wrap justify-center gap-8">
            <a href="/contact-us" class="bg-white text-black px-12 py-5 rounded-full font-semibold hover:scale-105 transition-all duration-500">
              Get Started
            </a>
            <a href="/services" class="border border-white/20 text-white px-12 py-5 rounded-full font-semibold hover:bg-white/10 hover:scale-105 transition-all duration-500">
              Our Services
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>
