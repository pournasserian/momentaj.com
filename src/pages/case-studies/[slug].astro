---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { marked } from 'marked';

// Generate static paths for all case studies
export async function getStaticPaths() {
  const caseStudies = await getCollection('case-studies');
  return caseStudies.map((study) => ({
    params: { slug: study.data.slug },
  }));
}

// Get the slug from the URL
const { slug } = Astro.params;

// Load case study data
const allCaseStudies = await getCollection('case-studies');
const caseStudyEntry = allCaseStudies.find(s => s.data.slug === slug);

// If not found, show 404
if (!caseStudyEntry) {
  return Astro.redirect('/404');
}

const caseStudy = caseStudyEntry.data;

// Get related case studies (other than current)
const relatedCaseStudies = allCaseStudies
  .filter(s => s.data.slug !== slug)
  .slice(0, 3)
  .map(s => s.data);

// Helper to render content
const isStructuredContent = typeof caseStudy.content === 'object';

const renderMarkdown = async (content: string) => {
  return await marked.parse(content);
};

const structuredContentHtml = isStructuredContent ? {
  overview: caseStudy.content.overview ? await renderMarkdown(caseStudy.content.overview) : null,
  challenge: caseStudy.content.challenge ? await renderMarkdown(caseStudy.content.challenge) : null,
  solution: caseStudy.content.solution ? await renderMarkdown(caseStudy.content.solution) : null,
  results: caseStudy.content.results ? await renderMarkdown(caseStudy.content.results) : null,
} : null;

const plainContentHtml = !isStructuredContent ? await renderMarkdown(caseStudy.content as string) : null;
---

<BaseLayout 
  title={`${caseStudy.title} Case Study | Momentaj`}
  description={caseStudy.description}
  keywords={`${caseStudy.tags?.join(', ')}, case study, software development, ${caseStudy.client}`}
>
  <Header />
  
  <main>
    <!-- Breadcrumbs -->
    <nav class="pt-32 bg-color-bg">
      <div class="container-custom py-4">
        <ol class="flex items-center gap-3 text-[11px] font-bold uppercase tracking-widest">
          <li><a href="/" class="text-color-text-light2 hover:text-color-primary transition-colors">Home</a></li>
          <li><span class="text-color-border">/</span></li>
          <li><a href="/case-studies" class="text-color-text-light2 hover:text-color-primary transition-colors">Case Studies</a></li>
          <li><span class="text-color-border">/</span></li>
          <li class="text-color-accent">{caseStudy.title}</li>
        </ol>
      </div>
    </nav>

    <!-- Hero -->
    <section class="pt-12 pb-24 bg-color-bg">
      <div class="container-custom">
        <div class="max-w-4xl animate-fade-in-up">
          <p class="text-[11px] font-bold text-color-accent mb-6 tracking-[0.2em] uppercase">{caseStudy.client}</p>
          <h1 class="hero-title mb-10">{caseStudy.title}</h1>
          <p class="hero-subtitle max-w-2xl mb-12">{caseStudy.description}</p>
          
          <div class="flex flex-wrap gap-6">
            {caseStudy.url && (
              <a href={caseStudy.url} target="_blank" rel="noopener noreferrer" class="btn-primary">
                Visit Website
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 00-2 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            )}
            <a href="/contact-us" class="btn-secondary">
              Start a Project
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Content -->
    <section class="section-padding bg-color-bg-alt border-t border-color-border/30">
      <div class="container-custom">
        <div class="grid lg:grid-cols-12 gap-20">
          <div class="lg:col-span-8 animate-fade-in-up animate-delay-200">
            {structuredContentHtml ? (
              <div class="space-y-20">
                {structuredContentHtml.overview && (
                  <div>
                    <h2 class="text-3xl font-semibold text-color-primary mb-8 tracking-tight">Overview</h2>
                    <div class="prose prose-lg dark:prose-invert max-w-none prose-p:text-color-text-light prose-p:leading-relaxed prose-p:text-[18px]" set:html={structuredContentHtml.overview} />
                  </div>
                )}
                {structuredContentHtml.challenge && (
                  <div>
                    <h2 class="text-3xl font-semibold text-color-primary mb-8 tracking-tight">The Challenge</h2>
                    <div class="prose prose-lg dark:prose-invert max-w-none prose-p:text-color-text-light prose-p:leading-relaxed prose-p:text-[18px]" set:html={structuredContentHtml.challenge} />
                  </div>
                )}
                {structuredContentHtml.solution && (
                  <div>
                    <h2 class="text-3xl font-semibold text-color-primary mb-8 tracking-tight">Our Solution</h2>
                    <div class="prose prose-lg dark:prose-invert max-w-none prose-p:text-color-text-light prose-p:leading-relaxed prose-p:text-[18px]" set:html={structuredContentHtml.solution} />
                  </div>
                )}
                {structuredContentHtml.results && (
                  <div>
                    <h2 class="text-3xl font-semibold text-color-primary mb-8 tracking-tight">Results</h2>
                    <div class="prose prose-lg dark:prose-invert max-w-none prose-p:text-color-text-light prose-p:leading-relaxed prose-p:text-[18px]" set:html={structuredContentHtml.results} />
                  </div>
                )}
              </div>
            ) : (
              <div class="prose prose-lg dark:prose-invert max-w-none prose-p:text-color-text-light prose-p:leading-relaxed prose-p:text-[18px]" set:html={plainContentHtml} />
            )}
          </div>
          
          <div class="lg:col-span-4 space-y-12 animate-fade-in-up animate-delay-300">
            {caseStudy.stats && (
              <div class="space-y-10">
                <h3 class="text-[11px] font-bold uppercase tracking-[0.2em] text-color-primary">Project Details</h3>
                <div class="space-y-10">
                  {caseStudy.stats.duration && (
                    <div>
                      <p class="text-[10px] font-bold uppercase tracking-widest text-color-text-light2 mb-2">Duration</p>
                      <p class="text-color-primary font-medium text-xl tracking-tight">{caseStudy.stats.duration}</p>
                    </div>
                  )}
                  {caseStudy.stats.teamSize && (
                    <div>
                      <p class="text-[10px] font-bold uppercase tracking-widest text-color-text-light2 mb-2">Team Size</p>
                      <p class="text-color-primary font-medium text-xl tracking-tight">{caseStudy.stats.teamSize}</p>
                    </div>
                  )}
                  {caseStudy.stats.technologies && (
                    <div>
                      <p class="text-[10px] font-bold uppercase tracking-widest text-color-text-light2 mb-4">Technologies</p>
                      <div class="flex flex-wrap gap-2">
                        {caseStudy.stats.technologies.map((tech) => (
                          <span class="px-3 py-1 bg-color-bg border border-color-border/50 rounded-full text-[10px] font-bold uppercase tracking-wider text-color-text-light">{tech}</span>
                        ))}
                      </div>
                    </div>
                  )}
                </div>
              </div>
            )}

            <div class="pt-10 border-t border-color-border/30">
              <h3 class="text-[11px] font-bold uppercase tracking-[0.2em] text-color-primary mb-4">Client</h3>
              <p class="text-color-text-light font-medium text-lg">{caseStudy.client}</p>
            </div>
            
            {caseStudy.tags && (
              <div class="pt-10 border-t border-color-border/30">
                <h3 class="text-[11px] font-bold uppercase tracking-[0.2em] text-color-primary mb-6">Services</h3>
                <ul class="space-y-4">
                  {caseStudy.tags.map((tag: string) => (
                    <li class="flex items-center gap-3 text-color-text-light font-medium">
                      <span class="w-1.5 h-1.5 rounded-full bg-color-accent"></span>
                      {tag}
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>

    <!-- Related Case Studies -->
    {relatedCaseStudies.length > 0 && (
      <section class="section-padding bg-color-bg border-t border-color-border/30">
        <div class="container-custom">
          <div class="text-center mb-20">
            <h2 class="section-title !text-3xl md:!text-4xl">Related Case Studies</h2>
          </div>
          <div class="grid md:grid-cols-3 gap-10">
            {relatedCaseStudies.map((study, index) => (
              <a href={`/case-studies/${study.slug}`} class={`case-study-card group animate-stagger animate-delay-${(index + 1) * 100}`}>
                <div class="h-56 bg-color-bg-alt flex items-center justify-center border-b border-color-border/50 overflow-hidden">
                  <div class="transform group-hover:scale-110 transition-transform duration-1000">
                    <svg class="w-16 h-16 text-color-text-light2 opacity-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                  </div>
                </div>
                <div class="p-10">
                  <div class="text-[10px] font-bold uppercase tracking-widest text-color-accent mb-3">{study.client}</div>
                  <h3 class="text-xl font-semibold group-hover:text-color-accent transition-colors leading-tight tracking-tight">{study.title}</h3>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="cta-section section-padding">
      <div class="container-custom">
        <div class="text-center max-w-3xl mx-auto">
          <h2 class="text-5xl md:text-6xl font-semibold text-white mb-10 tracking-tight">Have a Similar Project?</h2>
          <p class="text-xl text-white/60 mb-14 leading-relaxed">Let's discuss how we can help you achieve your goals with high-performance software.</p>
          <a href="/contact-us" class="bg-white text-black px-12 py-5 rounded-full font-semibold hover:scale-105 transition-all duration-500 inline-block">
            Get Started
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>
