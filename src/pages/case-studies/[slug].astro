---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCaseStudyBySlug, getCaseStudySlugs, getCaseStudies } from '../../lib/content';

// Generate static paths for all case studies
export function getStaticPaths() {
  const slugs = getCaseStudySlugs();
  return slugs.map((slug) => ({
    params: { slug },
  }));
}

// Get the slug from the URL
const { slug } = Astro.params;

// Load case study data
const caseStudy = getCaseStudyBySlug(slug);

// If not found, show 404
if (!caseStudy) {
  return Astro.redirect('/404');
}

// Get related case studies (other than current)
const allCaseStudies = getCaseStudies();
const relatedCaseStudies = allCaseStudies
  .filter(s => s.slug !== slug)
  .slice(0, 3)
  .map(s => ({ title: s.title, href: `/case-studies/${s.slug}` }));

// Parse content into sections
const contentSections = caseStudy.content ? caseStudy.content.split('\n\n') : [];
---

<BaseLayout 
  title={`${caseStudy.title} Case Study | Momentaj`}
  description={caseStudy.description}
>
  <Header />
  
  <main>
    <nav class="pt-24 bg-slate-50 border-b border-slate-200">
      <div class="container-custom py-3">
        <ol class="flex items-center gap-2 text-sm">
          <li><a href="/" class="text-slate-500 hover:text-primary">Home</a></li>
          <li><span class="text-slate-400">/</span></li>
          <li><a href="/case-studies" class="text-slate-500 hover:text-primary">Case Studies</a></li>
          <li><span class="text-slate-400">/</span></li>
          <li class="text-primary font-medium">{caseStudy.title}</li>
        </ol>
      </div>
    </nav>

    <!-- Hero -->
    <section class="py-16 bg-gradient-to-br from-primary to-primary-light">
      <div class="container-custom">
        <div class="max-w-4xl">
          <p class="text-accent font-medium mb-4">{caseStudy.client}</p>
          <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">{caseStudy.title}</h1>
          <p class="text-xl text-white/80 mb-8">{caseStudy.description}</p>
          {caseStudy.tags && (
            <div class="flex flex-wrap gap-4">
              {caseStudy.tags.split(',').map((tag: string) => (
                <span class="px-4 py-2 bg-white/10 rounded-full text-white text-sm">{tag.trim()}</span>
              ))}
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- Overview -->
    <section class="section-padding bg-white">
      <div class="container-custom">
        <div class="grid lg:grid-cols-3 gap-12">
          <div class="lg:col-span-2">
            {contentSections.map((section) => (
              <div class="mb-8">
                {section.startsWith('## ') ? (
                  <h2 class="text-2xl font-bold text-primary mb-4">{section.replace('## ', '')}</h2>
                ) : section.startsWith('### ') ? (
                  <h3 class="text-xl font-semibold text-primary mb-3">{section.replace('### ', '')}</h3>
                ) : (
                  <p class="text-slate-600 leading-relaxed">{section}</p>
                )}
              </div>
            ))}
          </div>
          
          <div class="space-y-8">
            <div class="bg-slate-50 rounded-xl p-6">
              <h3 class="font-semibold text-primary mb-4">Client</h3>
              <p class="text-slate-600">{caseStudy.client}</p>
            </div>
            
            {caseStudy.tags && (
              <div class="bg-slate-50 rounded-xl p-6">
                <h3 class="font-semibold text-primary mb-4">Services</h3>
                <ul class="space-y-2">
                  {caseStudy.tags.split(',').map((tag: string) => (
                    <li class="flex items-center gap-2 text-slate-600">
                      <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      {tag.trim()}
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>

    <!-- Related Case Studies -->
    {relatedCaseStudies.length > 0 && (
      <section class="section-padding bg-slate-50">
        <div class="container-custom">
          <h2 class="text-3xl font-bold text-primary mb-8 text-center">Related Case Studies</h2>
          <div class="grid md:grid-cols-3 gap-6">
            {relatedCaseStudies.map((study) => (
              <a href={study.href} class="bg-white p-6 rounded-xl hover:shadow-lg transition-shadow">
                <h3 class="text-lg font-semibold text-primary">{study.title}</h3>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="section-padding bg-primary">
      <div class="container-custom">
        <div class="text-center max-w-3xl mx-auto">
          <h2 class="text-3xl font-bold text-white mb-6">Have a Similar Project?</h2>
          <p class="text-xl text-white/80 mb-8">Let's discuss how we can help you achieve your goals.</p>
          <a href="/contact-us" class="bg-white text-primary px-8 py-4 rounded-lg font-semibold hover:bg-slate-100 transition-colors">
            Get Started
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>
