---
import { getEntry, getCollection } from 'astro:content';

const currentYear = new Date().getFullYear();

const settings = await getEntry('settings', 'settings');
const quickLinks = settings?.data?.navigation
  ? [...settings.data.navigation]
      .sort((a, b) => a.order - b.order)
      .map(item => ({ name: item.label, href: item.url }))
  : [];

const allServices = await getCollection('services');
const services = allServices.length > 0
  ? [...allServices]
      .sort((a, b) => a.data.order - b.data.order)
      .slice(0, 5)
      .map(s => ({ name: s.data.title, href: `/services/${s.data.slug}` }))
  : [];

const contactInfo = [
  { label: 'Email', value: settings?.data?.email || '', href: `mailto:${settings?.data?.email || ''}` },
  { label: 'Phone', value: settings?.data?.phone || '', href: `tel:${settings?.data?.phone?.replace(/\s+/g, '') || ''}` },
  { label: 'Address', value: settings?.data?.address || '', href: '#' },
];

const socialLinks = [];
if (settings?.data?.social_links?.linkedin) {
  socialLinks.push({ name: 'LinkedIn', href: settings.data.social_links.linkedin, icon: 'linkedin' });
}
if (settings?.data?.social_links?.twitter) {
  socialLinks.push({ name: 'X', href: settings.data.social_links.twitter, icon: 'x' });
}
if (settings?.data?.social_links?.github) {
  socialLinks.push({ name: 'GitHub', href: settings.data.social_links.github, icon: 'github' });
}
---

<footer class="bg-color-bg border-t border-color-border/50 pt-24 pb-12">
  <div class="container-custom">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-16 mb-20">
      <!-- Company Info -->
      <div class="lg:col-span-1">
        <a href="/" class="block mb-8 group invert dark:invert-0">
          {settings?.data?.logo ? (
            <img src={settings.data.logo} alt={settings.data.site_name} class="h-12 w-auto group-hover:opacity-70 transition-opacity" />
          ) : (
            <span class="text-2xl font-semibold text-color-primary tracking-tight group-hover:opacity-70 transition-opacity">
              {settings?.data?.site_name || 'Momentaj'}
            </span>
          )}
        </a>
        <p class="text-color-text-light text-[15px] leading-relaxed mb-8 max-w-xs">
          {settings?.data?.site_description || 'Based in Toronto, Momentaj is a software development and IT consulting company that provides customized solutions to businesses across various industries.'}
        </p>
        <div class="flex gap-5">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-color-text-light hover:text-color-primary transition-all duration-300 hover:scale-110"
              aria-label={social.name}
            >
              {social.icon === 'linkedin' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              )}
              {social.icon === 'x' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932 6.064-6.932zm-1.292 19.494h2.039L6.486 3.24H4.298l13.311 17.407z"/>
                </svg>
              )}
              {social.icon === 'github' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-xs font-bold uppercase tracking-[0.2em] text-color-primary mb-8">Quick Links</h4>
        <ul class="space-y-4">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-color-text-light hover:text-color-primary transition-colors text-[14px] font-medium">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-xs font-bold uppercase tracking-[0.2em] text-color-primary mb-8">Our Services</h4>
        <ul class="space-y-4">
          {services.map((service) => (
            <li>
              <a href={service.href} class="text-color-text-light hover:text-color-primary transition-colors text-[14px] font-medium">
                {service.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-xs font-bold uppercase tracking-[0.2em] text-color-primary mb-8">Get In Touch</h4>
        <ul class="space-y-6">
          {contactInfo.map((info) => (
            <li>
              <span class="text-color-text-light2 text-[10px] font-bold uppercase tracking-widest block mb-2">{info.label}</span>
              <a href={info.href} class="text-color-primary hover:text-color-accent transition-colors text-[14px] font-medium">
                {info.value}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="border-t border-color-border/50 pt-10">
      <div class="flex flex-col md:flex-row justify-between items-center gap-6">
        <p class="text-color-text-light2 text-[13px]">
          &copy; {currentYear} {settings?.data?.site_name || 'Momentaj'} Inc. All rights reserved.
        </p>
        <div class="flex gap-8">
          <a href="#" class="text-color-text-light2 hover:text-color-primary transition-colors text-[13px]">Privacy Policy</a>
          <a href="#" class="text-color-text-light2 hover:text-color-primary transition-colors text-[13px]">Terms of Service</a>
        </div>
      </div>
    </div>
  </div>
</footer>
