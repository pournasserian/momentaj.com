---
const currentYear = new Date().getFullYear();

const quickLinks = [
  { name: 'Home', href: '/' },
  { name: 'Services', href: '/services' },
  { name: 'Case Studies', href: '/case-studies' },
  { name: 'About Us', href: '/about-us' },
  { name: 'Contact Us', href: '/contact-us' },
];

const services = [
  { name: 'Web & Mobile App Development', href: '/services' },
  { name: 'Custom Software Development', href: '/services' },
  { name: 'UI/UX Design', href: '/services' },
  { name: 'Cloud & DevOps Engineering', href: '/services' },
  { name: 'IT Consultation', href: '/services' },
];

const contactInfo = [
  { label: 'Email', value: 'info@momentaj.com', href: 'mailto:info@momentaj.com' },
  { label: 'Address', value: '#204, 15 Wertheim Ct, Richmond Hill, ON L4B 3H7, Canada', href: '#' },
];

const socialLinks = [
  { name: 'LinkedIn', href: 'https://ca.linkedin.com/company/momentaj', icon: 'linkedin' },
];
---

<footer class="bg-primary text-white pt-16 pb-8">
  <div class="container-custom">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      <!-- Company Info -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center">
            <span class="text-primary font-bold text-xl">M</span>
          </div>
          <span class="text-xl font-bold">Momentaj</span>
        </a>
        <p class="text-slate-300 text-sm leading-relaxed mb-6">
          Based in Toronto, Momentaj is a software development and IT consulting company that provides customized solutions to businesses across various industries.
        </p>
        {socialLinks.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-slate-300 hover:text-white transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            <span class="text-sm">{social.name}</span>
          </a>
        ))}
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-semibold text-lg mb-6">Quick Links</h4>
        <ul class="space-y-3">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-slate-300 hover:text-white transition-colors text-sm">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4 class="font-semibold text-lg mb-6">Our Services</h4>
        <ul class="space-y-3">
          {services.map((service) => (
            <li>
              <a href={service.href} class="text-slate-300 hover:text-white transition-colors text-sm">
                {service.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-semibold text-lg mb-6">Get In Touch</h4>
        <ul class="space-y-4">
          {contactInfo.map((info) => (
            <li>
              <span class="text-slate-400 text-sm block mb-1">{info.label}</span>
              <a href={info.href} class="text-slate-300 hover:text-white transition-colors text-sm">
                {info.value}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="border-t border-slate-700 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-slate-400 text-sm">
          Copyright &copy; {currentYear}. Momentaj Inc
        </p>
        <div class="flex gap-6">
          <a href="#" class="text-slate-400 hover:text-white transition-colors text-sm">Privacy Policy</a>
          <a href="#" class="text-slate-400 hover:text-white transition-colors text-sm">Terms of Service</a>
        </div>
      </div>
    </div>
  </div>
</footer>
